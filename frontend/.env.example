# --- Firebase (Web app config from Firebase Console > Project settings) ---
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# --- Cloud Functions (Gen2 HTTPS trigger URL per function) ---
# Requests send Authorization: Bearer <Firebase ID token>; backend verifies with firebase-admin.
VITE_CF_LIST_QUARTER_SECTIONS_URL=
# Legacy placeholder name; prefer VITE_CF_GET_TREE_SHAP_EXPLANATION_URL for per-tree SHAP text.
VITE_CF_GET_QS_SHAP_DETAILS_URL=
# BigQuery: quarter-section polygons + summary only (no per-tree points).
VITE_CF_GET_QUARTER_SECTION_MAP_DATA_URL=
# BigQuery: trees for one QS (?qs_id=). Used when user clicks a section on the map.
VITE_CF_GET_TREES_BY_QS_URL=
# BigQuery: SHAP English explanation for one tree (?site_id=). Deploy getTreeShapExplanation and paste URL.
VITE_CF_GET_TREE_SHAP_EXPLANATION_URL=

# BigQuery: priority score history for quarter sections / districts (?scope=quarter_section|district).
# VITE_CF_GET_PRIORITY_HISTORY_URL=https://.../getPriorityHistory

# Optional Phase B: POST draft query JSON → tabular rows (BigQuery). When unset, analytics runs client-side on GeoJSON.
# VITE_CF_ANALYTICS_QUERY_URL=https://.../analytics_query
# Optional: GET field catalog metadata for the Data Dictionary.
# VITE_CF_ANALYTICS_SCHEMA_URL=https://.../analytics_schema

# Optional: MapLibre style JSON URL (defaults to Carto Positron; see frontend/src/map/riskLayers.js).
# VITE_MAP_STYLE_URL=https://basemaps.cartocdn.com/gl/positron-gl-style/style.json

# User registration + admin approval workflow (deploy accessApi).
# VITE_CF_ACCESS_API_URL=https://.../accessApi

# Optional: "Request Access" button opens mailto: this address (legacy).
# VITE_ACCESS_REQUEST_EMAIL=forestry@example.gov

# Firebase Console: enable Email/Password and/or Google sign-in; add localhost to Authorized domains for dev.
# Deployed functions must verify tokens (firebase-admin). Use the same GCP project as Firebase.
