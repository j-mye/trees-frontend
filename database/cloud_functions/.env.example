# Copy to `.env` for local Firebase emulator / tooling that loads env files.
# In Node you'd use process.env.BQ_PROJECT_ID; Cloud Functions here use os.environ with the same names.
# For deployed Gen2 functions, set the same keys via:
#   firebase functions:secrets:set ...   OR   params in firebase.json

# GCP project that owns the BigQuery dataset (hyphens ok, e.g. mke-trees).
BQ_PROJECT_ID=mke-trees

# Dataset id (single segment, no backticks).
BQ_DATASET=mke_tree_dataset

# Tree table id (full id = BQ_PROJECT_ID.BQ_DATASET.BQ_TREES_TABLE_NAME).
# Refactor default: trees_core
BQ_TREES_TABLE_NAME=trees_core
# Alias some teams use:
# BQ_TABLE_NAME=tree

# Quarter-section table id (single segment).
# Refactor default: quarter_sections
BQ_QUARTER_SECTION_TABLE_NAME=quarter_sections
# Alias:
# BQ_QS_TABLE_NAME=quarter_section

# Query job location MUST match where the dataset lives (job location = dataset region for regional datasets).
# This project uses the us-central1 regional dataset by default; set BQ_LOCATION=US only if the dataset is in the US multi-region.
# Copy this file to ``.env`` beside ``main.py``; it is loaded at startup via python-dotenv (does not override vars already set in the shell).
BQ_LOCATION=us-central1

# Cache-Control visibility for successful JSON (public or private). Use private for stricter CDN behavior.
# HTTP_CACHE_VISIBILITY=private

# Optional: full `project.dataset.table` overrides (skip composition above).
# BQ_TREES_TABLE=mke-trees.mke_tree_dataset.trees_core
# BQ_QS_SUMMARIES_TABLE=mke-trees.mke_tree_dataset.quarter_sections

# QS id column on the quarter-section table.
BQ_QS_ID_COLUMN=qs_id

# Quarter-section geometry column (GeoJSON STRING or GEOGRAPHY; exposed as geom_json text).
# Use `location` if your table stores polygons there instead of `geometry`.
BQ_QS_GEOMETRY_COLUMN=geometry

# Tree table column whose string value matches qs_id from the map.
BQ_TREE_QS_ID_COLUMN=qs_id

# SHAP explanations table (per-tree ``english_translation``). GET getTreeShapExplanation uses this.
# Optional full ``project.dataset.table`` override:
# BQ_SHAP_TABLE=mke-trees.mke_tree_dataset.shap
# Or table id under BQ_DATASET (default shap):
# BQ_SHAP_TABLE_NAME=shap
# Column to match ``site_id`` query param (allowlist: Site ID, site_id, tree_id, tree_row_id, Site_ID; default Site ID):
# BQ_SHAP_SITE_ID_COLUMN=Site ID
