{
  "functions": [
    {
      "source": "database/cloud_functions",
      "codebase": "default",
      "disallowLegacyRuntimeConfig": true,
      "ignore": [
        ".venv",
        "venv",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log",
        "*.local"
      ],
      "runtime": "python312"
    }
  ],
  "hosting": {
    "public": "frontend/dist",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [{ "source": "**", "destination": "/index.html" }]
  }
}
